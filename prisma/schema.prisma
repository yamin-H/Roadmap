generator client {
    provider = "prisma-client"
    output   = "../app/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        String    @id @default(uuid())
    name      String
    email     String    @unique
    password  String
    roadmaps  Roadmap[]
    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
}

model Roadmap {
    id          String   @id @default(uuid())
    title       String
    description String?
    nodes       Json?    @default("[]")
    edges       Json?    @default("[]")
    ownerId     String
    owner       User     @relation(fields: [ownerId], references: [id])
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}
